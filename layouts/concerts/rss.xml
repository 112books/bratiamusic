{{- $concerts := slice -}}
{{- $dataFile := "data/concerts.txt" -}}
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }} – Concerts</title>
    <link>{{ .Permalink }}</link>
    <description>Propers concerts de {{ .Site.Title }}</description>
    <language>{{ .Site.Language.Lang }}</language>
    <atom:link href="{{ .Permalink }}index.xml" rel="self" type="application/rss+xml"/>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    {{- range .Site.Pages -}}
      {{- if eq .Type "concerts" -}}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <description>{{ .Summary | html }}</description>
    </item>
      {{- end -}}
    {{- end -}}
  </channel>
</rss>